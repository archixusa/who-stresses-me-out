# === Telegram (bot icin zorunlu) ===
# Yeni bir bot olustur (@BotFather) veya mevcut logger botunun token'i.
TELEGRAM_BOT_TOKEN=
# Senin kisisel chat id'in. SADECE bu id loglayabilir + rapor buraya gider.
TELEGRAM_CHAT_ID=

# === Minute-level HR provider (undocumented WHOOP source, behind an adapter) ===
# unofficial = password login (below) · none = disable (official day-level still works)
HR_PROVIDER=unofficial
# NEVER commit this file (already git-ignored). Passwords/tokens stay on your machine.
WHOOP_EMAIL=
WHOOP_PASSWORD=
# Token-paste alternative (preferred over whoop_token.txt): a fresh access token
WHOOP_ACCESS_TOKEN=

# === Whoop RESMI OAuth API (Faz 2, opsiyonel: gunluk recovery/HRV + workout dislama) ===
# developer.whoop.com > uygulama olustur > Client ID/Secret + redirect URI ekle.
# Ayrinti: WHOOP_OAUTH_SETUP.md
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8080/callback
TOKEN_STORE_PATH=whoop_tokens.json

# === Otomatik baglam kaynaklari (opsiyonel — bkz. docs/AUTO_SOURCES_SETUP.md) ===
# Manuel loglama yerine takvim/Slack'ten "kimle birlikteydin" otomatik cekilir.
# Virgullu liste: google_calendar,slack  (bos birak = kapali)
AUTO_SOURCES=
# Google Calendar (pip install -r requirements-auto.txt)
GOOGLE_CREDENTIALS_PATH=google_credentials.json
GOOGLE_TOKEN_PATH=google_token.json
GOOGLE_CALENDAR_ID=primary
# Slack (User OAuth token xoxp-...; kapsamlar: im:history, im:read, users:read)
SLACK_TOKEN=
SLACK_GAP_MIN=20

# === Zaman dilimi (raporlar yerel saatte) ===
LOCAL_TZ=Europe/Istanbul

# === Analiz ayarlari ===
DEFAULT_WINDOW_MIN=90         # /bitir denmezse bulusma penceresi
MAX_WINDOW_MIN=240            # pencere tavani (gec /bitir korumasi)
TRIM_MINUTES=10              # pencere basindan (varis/yuruyus) kirp
BASELINE_PRE_MIN=90          # bulusma oncesi dinlenme baseline penceresi
MIN_BASELINE_SAMPLES=10
MIN_EVENT_SAMPLES=5
ELEVATION_THRESHOLD_BPM=12
SHRINK_K=2                   # kucuk-orneklem geri cekme gucu

# === SQLite + sync ===
DB_PATH=whoop_stress.db
SYNC_DAYS=8
HR_WINDOW_DAYS=7            # gayriresmi HR API pencere limiti (asma!)
